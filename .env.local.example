# ═══════════════════════════════════════════════════════════
#  JOSEPAN 360 · OMNI · [1002] Albaranes de Compras
#  api/.env.local.example — Plantilla de variables de entorno
#
#  USO:
#    1. Copia este archivo como api/.env.local
#    2. Rellena los valores reales
#    3. NUNCA subas .env.local al repositorio (está en .gitignore)
#
#  En producción NO uses este archivo: configura los SetEnv
#  directamente en el VirtualHost de Apache (ver MANUAL_DESPLIEGUE.md)
# ═══════════════════════════════════════════════════════════

# URL base del API CORE (sin /api/v1)
OMNI_API_BASE=https://api.omni.josepan.app

# Clave de la API de Anthropic (obligatoria para OCR)
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Token de servicio del API CORE (opcional)
# Permite cargar la lista de sedes en el login sin autenticación de usuario.
# Si no se define, se usa la lista estática de 17 sedes como fallback.
OMNI_SERVICE_TOKEN=
